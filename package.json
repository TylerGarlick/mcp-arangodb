{
  "name": "mcp-arangodb",
  "version": "1.0.0",
  "description": "Model Context Protocol server for ArangoDB with full graph support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-arangodb": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --outdir=dist --minifyify",
    "build:tsc": "tsc",
    "dev": "bun run ./src/index.ts",
    "dev:http": "bun run ./src/http-server.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:coverage": "bun test --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "arangodb": "^3.8.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "arangodb",
    "graph-database",
    "ai-tools"
  ],
  "author": "Tyler Garlick <tylergarlick@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylerGarlick/mcp-arangodb"
  }
}
